rules_version = '2';

//
// Wellness Medicals HMS – Firestore Security Rules
//
// CURRENT MODE: Development-safe (anonymous auth required)
// ─────────────────────────────────────────────────────────────
// These rules allow any anonymously-authenticated user to
// read and write all HMS collections.
//
// ⚠️  TO TIGHTEN FOR PRODUCTION:
//   1. Set up proper user accounts in Firebase Authentication.
//   2. Add custom claims (e.g. { role: "staff" }) via Admin SDK
//      or Cloud Functions.
//   3. Replace the isAuth() function below with:
//        function isStaff() {
//          return request.auth != null
//              && request.auth.token.role == 'staff';
//        }
//      and use isStaff() in every rule instead of isAuth().
// ─────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // No authentication required in this mode
    function isAuth() {
      return true;
    }

    // Patients collection – full CRUD for authenticated users
    match /patients/{patientId} {
      allow read, create, update, delete: if isAuth();
    }

    // Appointments collection – full CRUD for authenticated users
    match /appointments/{appointmentId} {
      allow read, create, update, delete: if isAuth();
    }

    // Doctors collection – read-only (managed via Admin SDK or console)
    match /doctors/{doctorId} {
      allow read: if isAuth();
      allow write: if false; // Lock via console or Admin SDK
    }

    // Wards collection – read and update only (no delete)
    match /wards/{wardId} {
      allow read, update: if isAuth();
      allow create: if isAuth();
      allow delete: if false;
    }

    // Deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
